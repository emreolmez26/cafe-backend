generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Category {
  id       Int       @id @default(autoincrement())
  name     String    
  products Product[] 
}

model Product {
  id           Int      @id @default(autoincrement())
  name         String
  price        Float
  
  // YENİ EKLENEN TASARIM ALANLARI
  description  String?  // Kısa açıklama (? işareti zorunlu olmadığını belirtir)
  imageUrl     String?  // Resim linki
  subCategory  String?  // Alt seçenek (Örn: Fast Food)
  extraOptions String?  // Ekstra malzemeler (Örn: "Ketçap, Mayonez")

  isAvailable  Boolean  @default(true) // Menüde göster/gizle butonu için

  categoryId   Int
  category     Category @relation(fields: [categoryId], references: [id])
  orderItems   OrderItem[]
}

model Table {
  id           Int      @id @default(autoincrement())
  tableNumber  Int      @unique 
  status       String   @default("BOŞ") // "BOŞ" veya "DOLU"
  sessionPin   String?  // Garsonun oluşturduğu 4 haneli kod
  sessionToken String?  // Güvenlik için arka plandaki uzun anahtar
  orders       Order[]  
}

model Order {
  id          Int         @id @default(autoincrement())
  status      String      @default("BEKLİYOR") 
  totalAmount Float       @default(0) 
  paidAmount  Float       @default(0) 
  createdAt   DateTime    @default(now()) 
  tableId     Int         
  table       Table       @relation(fields: [tableId], references: [id])
  items       OrderItem[] 
}

model OrderItem {
  id        Int      @id @default(autoincrement())
  quantity  Int      @default(1) 
  notes     String?  
  orderId   Int      
  order     Order    @relation(fields: [orderId], references: [id])
  productId Int      
  product   Product  @relation(fields: [productId], references: [id])
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String   // Şifrelenmiş halde saklanacak
  role      String   @default("WAITER") // "ADMIN" veya "WAITER"
  createdAt DateTime @default(now())
}